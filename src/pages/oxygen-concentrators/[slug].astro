---
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import ProductLayout from '../../layouts/ProductLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export const getStaticPaths = (async () => {
  const products = await getCollection('products');
  return products.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

interface Props {
  entry: CollectionEntry<'products'>;
}

const { entry } = Astro.props;
const { data } = entry;

const review = await getEntry('product-reviews', data.slug);
const ReviewContent = review ? (await render(review)).Content : null;
const reviewFrontmatter = review?.data ?? undefined;

const brandLabel = data.brand ? `${data.brand} ` : '';
const fallbackDescription =
  `${brandLabel}${data.product_name} review — specs, price, pros and cons. Independent review by HHZ Respiratory Review.`.trim();

function buildDescription(): string {
  const raw = (data.description_text ?? '').replace(/\s+/g, ' ').trim();
  if (raw.length >= 120) {
    if (raw.length <= 160) return raw;
    const truncated = raw.slice(0, 157);
    const lastSpace = truncated.lastIndexOf(' ');
    return `${truncated.slice(0, lastSpace > 120 ? lastSpace : 157)}…`;
  }
  return fallbackDescription.length > 160
    ? `${fallbackDescription.slice(0, 157)}…`
    : fallbackDescription;
}

const description = buildDescription();
const title = reviewFrontmatter?.title ?? `${data.product_name} review`;
const canonicalURL = new URL(
  `/oxygen-concentrators/${data.slug}/`,
  Astro.site
).toString();
---
<ProductLayout
  product={data}
  category="oxygen-concentrators"
  categoryLabel="Oxygen concentrators"
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  reviewFrontmatter={reviewFrontmatter}
>
  {ReviewContent && <ReviewContent />}
</ProductLayout>
