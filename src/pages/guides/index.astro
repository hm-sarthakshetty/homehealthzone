---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');

// Sort by lastReviewed desc when present, then by title.
const sorted = guides.slice().sort((a, b) => {
  const aDate = a.data.lastReviewed ?? '';
  const bDate = b.data.lastReviewed ?? '';
  if (aDate && bDate && aDate !== bDate) return bDate.localeCompare(aDate);
  return a.data.title.localeCompare(b.data.title, 'en');
});

const pageTitle = "Buyer's guides";
const description =
  'How to choose the right oxygen concentrator, CPAP, or BiPAP — how to read a spec sheet, what to ignore, what actually matters in Indian conditions.';

const crumbs = [
  { href: '/', label: 'Home' },
  { href: '/guides/', label: 'Guides' },
];

const featuredClusters = [
  {
    title: '5 LPM buying decisions',
    links: [
      ['Oxygen concentrators buyer guide', '/guides/oxygen-concentrators-buyers-guide-india/'],
      ['Home Medix vs Oxymed vs Philips EverFlo', '/guides/home-medix-vs-oxymed-vs-philips-everflo-india/'],
      ['Quiet and lightweight 5 LPM concentrators', '/guides/quiet-lightweight-5-lpm-oxygen-concentrators-india/'],
    ],
  },
  {
    title: 'EverFlo and imported-stock risk',
    links: [
      ['Philips EverFlo replacement in India', '/guides/philips-everflo-replacement-india/'],
      ['Should you buy Philips EverFlo now?', '/guides/should-you-buy-philips-everflo-india/'],
      ['Imported oxygen concentrator spare parts', '/guides/imported-oxygen-concentrator-spare-parts-india/'],
    ],
  },
  {
    title: 'Dealer, warranty, and stock checks',
    links: [
      ['Old stock oxygen concentrators in India', '/guides/old-stock-oxygen-concentrator-india/'],
      ['New vs refurbished concentrator checks', '/guides/how-to-check-new-vs-refurbished-oxygen-concentrator/'],
      ['Warranty and serial-number check', '/guides/oxygen-concentrator-warranty-serial-number-check-india/'],
    ],
  },
];
---
<BaseLayout title={pageTitle} description={description}>
  <Breadcrumbs items={crumbs} />

  <header class="hub-header">
    <h1>{pageTitle}</h1>
    <p class="lead">
      Plain-English guides to buying respiratory equipment in India — how to read a spec sheet,
      which features matter, which are marketing fluff, and how to avoid the most common
      mistakes. Reviewed periodically and timestamped.
    </p>
  </header>

  <section class="featured-guides" aria-labelledby="featured-guides-heading">
    <h2 id="featured-guides-heading">High-intent guide clusters</h2>
    <div class="featured-guides__grid">
      {featuredClusters.map((cluster) => (
        <article class="featured-guides__cluster">
          <h3>{cluster.title}</h3>
          <ul>
            {cluster.links.map(([label, href]) => (
              <li><a href={href}>{label}</a></li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  {sorted.length === 0 ? (
    <p class="empty">No guides published yet.</p>
  ) : (
    <div class="article-grid">
      {sorted.map((entry) => (
        <ArticleCard entry={entry} href={`/guides/${entry.id}/`} />
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .hub-header {
    margin-bottom: var(--space-8);
  }
  .featured-guides {
    margin-bottom: var(--space-8);
  }
  .featured-guides h2 {
    margin-bottom: var(--space-4);
  }
  .featured-guides__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .featured-guides__cluster {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
    background: var(--color-surface);
  }
  .featured-guides__cluster h3 {
    margin-top: 0;
    font-size: var(--text-lg);
  }
  .featured-guides__cluster ul {
    margin-bottom: 0;
    padding-left: var(--space-5);
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-5);
  }
  .empty {
    color: var(--color-text-muted);
  }
</style>
