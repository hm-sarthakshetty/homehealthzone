---
/**
 * Renders a <picture> element with AVIF + WebP sources (generated by
 * scripts/optimize_images.mjs into /images/opt/) and a JPG fallback.
 * If `src` isn't under /images/products/, falls back to a plain <img>.
 */
export interface Props {
  src: string;
  alt: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  /** Intrinsic width in CSS pixels — used by browser for layout reservation. */
  width?: number;
  /** Intrinsic height in CSS pixels — used by browser for layout reservation. */
  height?: number;
}

const {
  src,
  alt,
  loading = 'lazy',
  fetchpriority,
  class: className,
  // Defaults reflect the 4:3 aspect the CSS renders at on cards + hero images.
  // Declared attributes let the browser reserve layout space before the image
  // decodes, eliminating a CLS contribution and letting LCP elements paint sooner.
  width = 800,
  height = 600,
} = Astro.props;

const PREFIX = '/images/products/';
const OPT_PREFIX = '/images/opt/';

let webpSrc: string | null = null;
let avifSrc: string | null = null;

if (src.startsWith(PREFIX)) {
  const file = src.slice(PREFIX.length);
  const stem = file.replace(/\.(jpe?g|png)$/i, '');
  webpSrc = `${OPT_PREFIX}${stem}.webp`;
  avifSrc = `${OPT_PREFIX}${stem}.avif`;
}
---
{avifSrc && webpSrc ? (
  <picture>
    <source srcset={avifSrc} type="image/avif" />
    <source srcset={webpSrc} type="image/webp" />
    <img
      src={src}
      alt={alt}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
      decoding="async"
      width={width}
      height={height}
    />
  </picture>
) : (
  <img
    src={src}
    alt={alt}
    loading={loading}
    fetchpriority={fetchpriority}
    class={className}
    decoding="async"
    width={width}
    height={height}
  />
)}
